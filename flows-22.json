        "id": "0cfa70ea6b0b347e",
        "type": "function",
        "z": "464d08b033e59563",
        "name": "Normalize Alert",
        "func": "let p = msg.payload;\n\n// Parse if string\nif (typeof p === \"string\") {\n    try { p = JSON.parse(p); }\n    catch (e) { }\n}\n\np = p || {};\n\n// Read anomaly from ML\nlet isAnomaly =\n    (p.isAnomaly !== undefined) ? p.isAnomaly :\n        (p.is_anomaly !== undefined) ? p.is_anomaly :\n            (p.anomaly !== undefined) ? p.anomaly :\n                0;\n\nisAnomaly = (Number(isAnomaly) === 1) ? 1 : 0;\n\n// 🔥 GET ATTACK STATE\nlet attackEnabled = global.get(\"attackEnabled\") || false;\n\n// 🔥 FORCE NORMAL WHEN ATTACK OFF\nif (!attackEnabled) {\n    isAnomaly = 0;\n}\n\n// Store back\np.is_anomaly = isAnomaly;\np.status = (isAnomaly === 1) ? \"ATTACK DETECTED\" : \"NORMAL\";\n\nmsg.payload = p;\n\n// Debug\nif (isAnomaly === 1) {\n    node.warn(\"🚨 ALERT: ATTACK DETECTED for \" + (p.patient_id || \"UNKNOWN\"));\n} else {\n    node.warn(\"✅ NORMAL for \" + (p.patient_id || \"UNKNOWN\"));\n}\n\nreturn msg;",
