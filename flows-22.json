        "type": "function",
        "z": "464d08b033e59563",
        "name": "AI Router",
        "func": "let p = msg.payload;\n\nif (typeof p === \"string\") {\n    try { p = JSON.parse(p); } catch (e) {}\n}\np = p || {};\n\nlet key = p.patient_id || p.device_id || (\"row_\" + Date.now());\n\n// Track current status of each patient/device\nlet statusMap = flow.get(\"ai_status_map\") || {};\nstatusMap[key] = p.status || \"NORMAL\";\nflow.set(\"ai_status_map\", statusMap);\n\n// If this message is an attack, send it to Ollama\nif (p.status === \"ATTACK DETECTED\") {\n    msg.originalPayload = p;\n    return [msg, null];\n}\n\n// If no active attacks remain, clear the AI box\nlet anyAttack = Object.values(statusMap).some(v => v === \"ATTACK DETECTED\");\n\nif (!anyAttack) {\n    p.ai_explanation = \"No active attack detected.\";\n    msg.payload = p;\n    return [null, msg];\n}\n\n// Otherwise do nothing\nreturn [null, null];",
