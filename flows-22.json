    {
        "id": "cd364cd17a00668f",
        "type": "function",
        "z": "464d08b033e59563",
        "name": "HR Decryption",
        "func": "const CryptoJS = global.get(\"CryptoJS\");\nconst key = CryptoJS.SHA256(\"hospital-secure-key\");\n\nlet p = msg.payload;\nif (Buffer.isBuffer(p)) p = p.toString(\"utf8\");\nif (typeof p === \"string\") p = JSON.parse(p);\n\nif (!p._encrypted || !p.encryptedData || !p.iv) {\n    node.warn(\"Skipping non-encrypted message\");\n    return null;\n}\n\nconst decrypted = CryptoJS.AES.decrypt(\n    {\n        ciphertext: CryptoJS.enc.Base64.parse(p.encryptedData)\n    },\n    key,\n    {\n        iv: CryptoJS.enc.Base64.parse(p.iv),\n        mode: CryptoJS.mode.CBC,\n        padding: CryptoJS.pad.Pkcs7\n    }\n);\n\nconst text = decrypted.toString(CryptoJS.enc.Utf8);\nif (!text) {\n    node.error(\"Decryption failed\");\n    return null;\n}\n\nmsg.payload = JSON.parse(text);\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 700,
        "wires": [
