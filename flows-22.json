    {
        "id": "c7622594985e328c",
        "type": "function",
        "z": "464d08b033e59563",
        "d": true,
        "name": "LLM Prompt Builder",
        "func": "let p = msg.payload;\n\nif (typeof p === \"string\") {\n    try { p = JSON.parse(p); } catch (e) {}\n}\np = p || {};\n\nconst patientId = p.patient_id || \"Unknown\";\nconst patientName = p.patient_name || \"Unknown\";\nconst deviceId = p.device_id || \"Unknown\";\nconst status = p.status || \"Unknown\";\nconst score = (p.anomaly_score !== undefined) ? p.anomaly_score : \"N/A\";\nconst threshold = (p.threshold !== undefined) ? p.threshold : \"N/A\";\nconst time = p.timestamp || new Date().toISOString();\n\nmsg.originalPayload = p;\n\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\n\nmsg.payload = {\n    model: \"llama3.2\",\n    stream: false,\n    messages: [\n        {\n            role: \"system\",\n            content: \"You are a hospital IoT cybersecurity assistant. Explain IDS alerts in simple, short language for hospital staff. Mention possible MITM or data manipulation if suspicious. Give one short recommended action. Do not give medical advice.\"\n        },\n        {\n            role: \"user\",\n            content:\n`Patient ID: ${patientId}\nPatient Name: ${patientName}\nDevice ID: ${deviceId}\nStatus: ${status}\nAnomaly Score: ${score}\nThreshold: ${threshold}\nTimestamp: ${time}\n\nExplain this alert for hospital staff in 2 short sentences.`\n        }\n    ]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
