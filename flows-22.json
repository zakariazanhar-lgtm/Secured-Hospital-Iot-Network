    {
        "id": "0c3292c9bcfd794d",
        "type": "function",
        "z": "464d08b033e59563",
        "name": "HR Encryption",
        "func": "if (!msg.payload || typeof msg.payload !== \"object\") {\n    node.warn(\"Invalid payload for encryption\");\n    return null;\n}\n\nconst CryptoJS = global.get(\"CryptoJS\");\nconst key = CryptoJS.SHA256(\"hospital-secure-key\");\n\nconst iv = CryptoJS.lib.WordArray.random(16);\n\nconst encrypted = CryptoJS.AES.encrypt(\n    JSON.stringify(msg.payload),\n    key,\n    {\n        iv,\n        mode: CryptoJS.mode.CBC,\n        padding: CryptoJS.pad.Pkcs7\n    }\n);\n\nmsg.payload = {\n    _encrypted: true,\n    encryptedData: encrypted.ciphertext.toString(CryptoJS.enc.Base64),\n    iv: iv.toString(CryptoJS.enc.Base64)\n};\n\nreturn msg;\n\n\n\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 520,
        "y": 540,
