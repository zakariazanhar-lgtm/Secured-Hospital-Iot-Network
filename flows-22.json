    {
        "id": "f65f6ba1629e83e7",
        "type": "function",
        "z": "464d08b033e59563",
        "name": "MITM Attck",
        "func": "let ATTACK_ENABLED = global.get(\"attackEnabled\") || false;\n\nif (msg.topic === \"attack\") {\n\n    global.set(\"attackEnabled\", msg.payload);\n\n    node.warn(\"MITM Attack set to: \" + msg.payload);\n\n    return null;\n}\n\nlet payload = JSON.parse(JSON.stringify(msg.payload));\n\nconst TARGET_PATIENT = \"PAT-001\";\n\nconst FORCED_HR = Math.floor(Math.random() * (85 - 55 + 1)) + 115;\n\nconst pid = payload.patient_id || payload.patientId;\n\nif (ATTACK_ENABLED && pid === TARGET_PATIENT) {\n\n    if (payload.data && payload.data.heartRate !== undefined) {\n\n        payload.data.heartRate = FORCED_HR;\n\n    }\n\n    payload.attackFlag = true;\n\n    payload.attackType = \"MITM - Data Manipulation\";\n\n}\n\nmsg.payload = payload;\n\nreturn msg;",
